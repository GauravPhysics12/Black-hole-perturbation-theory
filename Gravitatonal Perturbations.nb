      RowBox[{"I", " ", "m", " ", 
       RowBox[{"Y", "[", "\[Chi]", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"Sin", "[", "\[Theta]", "]"}], "*", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 

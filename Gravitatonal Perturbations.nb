Cell[CellGroupData[{

Cell[TextData[{
 "Cos[\[Theta]] = \[Chi]\nSin[\[Theta]] = ",
 Cell[BoxData[
  FormBox[
   SqrtBox[
    RowBox[{"1", "-", 
     SuperscriptBox["\[Chi]", "2"]}]], TraditionalForm]],ExpressionUUID->
  "c29410fa-34b9-48eb-b03d-5f9a0e582636"],
 "\n d\[Chi] = -Sin[\[Theta]] d\[Theta]  => d\[Theta] = -d\[Chi] ",
 Cell[BoxData[
  FormBox[
   RowBox[{"/", 
    SqrtBox[
     RowBox[{"1", "-", 
      SuperscriptBox["\[Chi]", "2"]}]]}], TraditionalForm]],ExpressionUUID->
  "a7e0ba64-fdbb-457c-9669-3439fe5f84a9"],
 " \n \n And very importantly you will notice the Ylm[\[Theta], \[Phi]] going \
to Ylm[\[Chi]], and the very end step we will justify where is this \[Phi] \
dependence vanishing"
}], "Subsubsection",
 CellChangeTimes->{{3.9833666909624147`*^9, 
  3.9833669127911453`*^9}},ExpressionUUID->"357cb64e-0df5-44b9-b2ad-\
6b44db074d38"],


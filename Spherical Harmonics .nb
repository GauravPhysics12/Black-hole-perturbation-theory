    360., {186., 191.}}, Typeset`update$$ = 0, Typeset`initDone$$, 
    Typeset`skipInitDone$$ = True}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`l$$ = 3, $CellContext`m$$ = 0}, 
      "ControllerVariables" :> {}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> 
      Module[{$CellContext`H11$, $CellContext`H12$, $CellContext`H22$, \
$CellContext`S11$, $CellContext`S12$, $CellContext`S22$, $CellContext`ev1$}, \
$CellContext`H11$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := ReplaceAll[
           Re[
            D[
             
             SphericalHarmonicY[$CellContext`l$$, $CellContext`m$$, \
$CellContext`t, $CellContext`p], $CellContext`t, $CellContext`t]], \
{$CellContext`t -> $CellContext`th$, $CellContext`p -> $CellContext`ph$}]; \
$CellContext`H12$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := ReplaceAll[
           Re[D[
              
              SphericalHarmonicY[$CellContext`l$$, $CellContext`m$$, \
$CellContext`t, $CellContext`p], $CellContext`t, $CellContext`p] - (
             Cos[$CellContext`t]/Sin[$CellContext`t]) D[
              
              SphericalHarmonicY[$CellContext`l$$, $CellContext`m$$, \
$CellContext`t, $CellContext`p], $CellContext`p]], {$CellContext`t -> \
$CellContext`th$, $CellContext`p -> $CellContext`ph$}]; $CellContext`H22$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := ReplaceAll[
           Re[D[
              
              SphericalHarmonicY[$CellContext`l$$, $CellContext`m$$, \
$CellContext`t, $CellContext`p], $CellContext`p, $CellContext`p] + 
            Sin[$CellContext`t] Cos[$CellContext`t] D[
               
               SphericalHarmonicY[$CellContext`l$$, $CellContext`m$$, \
$CellContext`t, $CellContext`p], $CellContext`t]], {$CellContext`t -> \
$CellContext`th$, $CellContext`p -> $CellContext`ph$}]; $CellContext`S11$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := (1/
           Sin[$CellContext`th$]) $CellContext`H12$[$CellContext`th$, \
$CellContext`ph$]; $CellContext`S12$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := (1/
           2) ((1/Sin[$CellContext`th$]) $CellContext`H22$[$CellContext`th$, \
$CellContext`ph$] - 
           Sin[$CellContext`th$] $CellContext`H11$[$CellContext`th$, \
$CellContext`ph$]); $CellContext`S22$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := (-
           Sin[$CellContext`th$]) $CellContext`H12$[$CellContext`th$, \
$CellContext`ph$]; $CellContext`ev1$[
           Pattern[$CellContext`th$, 
            Blank[]], 
           Pattern[$CellContext`ph$, 
            Blank[]]] := (1/
           2) ($CellContext`S11$[$CellContext`th$, $CellContext`ph$] + \
$CellContext`S22$[$CellContext`th$, $CellContext`ph$] + Sqrt[
             Max[
             0, ($CellContext`S11$[$CellContext`th$, $CellContext`ph$] - \
$CellContext`S22$[$CellContext`th$, $CellContext`ph$])^2 + 
              4 $CellContext`S12$[$CellContext`th$, $CellContext`ph$]^2]]); 
        SphericalPlot3D[
         1, {$CellContext`th, 0.05, Pi - 0.05}, {$CellContext`ph, 0, 2 Pi}, 
          ColorFunction -> 
          Function[{$CellContext`x$, $CellContext`y$, $CellContext`z$, \
$CellContext`th$, $CellContext`ph$}, 

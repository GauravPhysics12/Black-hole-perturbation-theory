       RowBox[{"2", " ", "M"}], ",", "r"}], "]"}], ",", 
     RowBox[{"Veff", "[", 
      RowBox[{"M", ",", "r"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", 
     RowBox[{"2.01", " ", "M"}], ",", 
     RowBox[{"25", " ", "M"}]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{"0.6", ",", "1.4"}], "}"}]}], ",", 
   RowBox[{"AxesLabel", "->", 

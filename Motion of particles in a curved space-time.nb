     RowBox[{"2", " ", "M", " ", 
      RowBox[{"b", "^", "2"}]}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"poly", "[", 
      RowBox[{"r", ",", "b"}], "]"}], ",", 

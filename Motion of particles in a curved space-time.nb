Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Clear", " ", "previous", " ", "definitions", " ", "to", " ", 
    "prevent", " ", "conflicts"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"M", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "r_", "]"}], ":=", 
     RowBox[{"1", "-", 
      RowBox[{"2", "*", 
       RowBox[{"M", "/", "r"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"Veff", "[", "r_", "]"}], ":=", 
     RowBox[{
      RowBox[{"f", "[", "r", "]"}], "/", 
      RowBox[{"r", "^", "2"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"2.", " ", "Pre"}], "-", 
     RowBox[{
     "calculate", " ", "the", " ", "derivatives", " ", "symbolically", " ", 
      "ONCE"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Notice", " ", "we", " ", "use", " ", "\"\<=\>\"", " ", "instead", " ", 
     "of", " ", "\"\<:=\>\"", " ", "so", " ", "it", " ", "evaluates", " ", 
     "immediately"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"d2VdrStar2", "[", "r_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "r", "]"}], "*", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"f", "[", "x", "]"}], "*", 
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Veff", "[", "x", "]"}], ",", "x"}], "]"}]}], ",", "x"}],
          "]"}]}], "/.", " ", 
       RowBox[{"x", "->", "r"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Define", " ", "the", " ", "Lyapunov", " ", "function"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lambdaNullFunc", "[", "r_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "2", "]"}]}], "*", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"r", "^", "2"}], "/", 
             RowBox[{"f", "[", "r", "]"}]}], ")"}]}], "*", 
          RowBox[{"d2VdrStar2", "[", "r", "]"}]}], "]"}], "]"}]}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Evaluate", " ", "at", " ", "the", " ", "peak"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rc", "=", 
     RowBox[{"3", "*", "M"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lambdaPeak", "=", 
     RowBox[{"lambdaNullFunc", "[", "rc", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Numerical evaluated value at 3M: \>\"", ",", "lambdaPeak"}],
      "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Plot"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"lambdaNullFunc", "[", "r", "]"}], ",", 
     RowBox[{"{", 

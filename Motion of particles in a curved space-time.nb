Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Schwarzschild", " ", "Metric", " ", "Parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"M", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "r_", "]"}], ":=", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"2", " ", "M"}], ")"}], "/", "r"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"h", "[", "r_", "]"}], ":=", 
     RowBox[{"f", "[", "r", "]"}]}], ";", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"In", " ", "Schwarzschild"}], ",", 
      RowBox[{
       RowBox[{"g", "^", "rr"}], "=", 
       RowBox[{"g_tt", "=", "f"}]}]}], "*)"}], 
    RowBox[{"(*", 
     RowBox[{
     "1.", " ", "Second", " ", "Derivative", " ", "of", " ", "Potential", " ",
       "for", " ", "Timelike", " ", "Geodesics"}], "*)"}], 
    RowBox[{"(*", 
     RowBox[{"Using", " ", 
      RowBox[{"Eq", ".", "2.4"}], ".69", " ", "from", " ", "your", " ", 
      "text"}], "*)"}], 
    RowBox[{
     RowBox[{"f1", "[", "r_", "]"}], ":=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], ",", "x"}], "]"}], "/.", " ", 
      RowBox[{"x", "->", "r"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"f2", "[", "r_", "]"}], ":=", 
     RowBox[{
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"x", ",", "2"}], "}"}]}], "]"}], "/.", " ", 
      RowBox[{"x", "->", "r"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"Vr2", "[", "r_", "]"}], ":=", 
     RowBox[{"2", " ", 
      RowBox[{"h", "[", "r", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"f", "[", "r", "]"}], "/", 
        RowBox[{"r", "^", "2"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "3"}], " ", 
           RowBox[{"f", "[", "r", "]"}], " ", 
           RowBox[{
            RowBox[{"f1", "[", "r", "]"}], "/", "r"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{
            RowBox[{"f1", "[", "r", "]"}], "^", "2"}]}], "-", 
          RowBox[{
           RowBox[{"f", "[", "r", "]"}], " ", 
           RowBox[{"f2", "[", "r", "]"}]}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"f", "[", "r", "]"}]}], "-", 
          RowBox[{"r", " ", 
           RowBox[{"f1", "[", "r", "]"}]}]}], ")"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Lyapunov", " ", "Exponent", " ", "lambda0", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Eq", ".", "2.4"}], ".71"}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"lambdaTimelike", "[", "r_", "]"}], ":=", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"Max", "[", 
       RowBox[{"0", ",", 
        RowBox[{
         RowBox[{"1", "/", "2"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"f", "[", "r", "]"}]}], "-", 
           RowBox[{"r", " ", 
            RowBox[{"f1", "[", "r", "]"}]}]}], ")"}], " ", 
         RowBox[{"Vr2", "[", "r", "]"}]}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Null", " ", "Geodesic", " ", "Value", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Single", " ", "Point", " ", "at", " ", "r"}], "=", 
       RowBox[{"3", "M"}]}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"lambdaNull", "=", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sqrt", "[", "3", "]"}], " ", "3", " ", "M"}], ")"}]}]}], ";", 
    RowBox[{"(*", 
     RowBox[{"Analytical", " ", "value", " ", "for", " ", "Schwarzschild"}], 
     "*)"}], 
    RowBox[{"(*", 
     RowBox[{"4.", " ", "Plotting"}], "*)"}], 
    RowBox[{"Plot", "[", 
     RowBox[{
      RowBox[{"lambdaTimelike", "[", "r", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"r", ",", 
        RowBox[{"2.01", " ", "M"}], ",", 
        RowBox[{"8", " ", "M"}]}], "}"}], ",", 
      RowBox[{"PlotRange", "->", "All"}], ",", 
      RowBox[{"Filling", "->", "Axis"}], ",", 
      RowBox[{"PlotStyle", "->", 
       RowBox[{"{", 
        RowBox[{"Thick", ",", "Blue"}], "}"}]}], ",", 
      RowBox[{"AxesLabel", "->", 
       RowBox[{"{", 
        RowBox[{"\"\<r/M\>\"", ",", "\"\<\[Lambda]0\>\""}], "}"}]}], ",", 
      RowBox[{
      "PlotLabel", "->", 
       "\"\<Lyapunov Exponent for Timelike Circular Orbits\>\""}], ",", 
      RowBox[{"Epilog", "->", 
       RowBox[{"{", 
        RowBox[{"Red", ",", 
         RowBox[{"PointSize", "[", "Large", "]"}], ",", 

  RowBox[{
   RowBox[{"equatorialGeodesics", "[", 
    RowBox[{"[", "4", "]"}], "]"}], "*", 
   RowBox[{
    RowBox[{"r", "[", "\[Lambda]", "]"}], "^", "2"}]}], "//", 
  "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.982474266217367*^9, 3.982474266943111*^9}, {
  3.9824745612756557`*^9, 3.982474594630692*^9}},
 CellLabel->
  "In[148]:=",ExpressionUUID->"1ec8dc14-40fe-4822-b339-acf218e4b43e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"r", "[", "\[Lambda]", "]"}], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"2", " ", 
     RowBox[{
      SuperscriptBox["r", "\[Prime]",
       MultilineFunction->None], "[", "\[Lambda]", "]"}], " ", 
     RowBox[{
      SuperscriptBox["\[Phi]", "\[Prime]",
       MultilineFunction->None], "[", "\[Lambda]", "]"}]}], "+", 
    RowBox[{
     RowBox[{"r", "[", "\[Lambda]", "]"}], " ", 
     RowBox[{
      SuperscriptBox["\[Phi]", "\[Prime]\[Prime]",
       MultilineFunction->None], "[", "\[Lambda]", "]"}]}]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{{3.982474562444048*^9, 3.982474595130661*^9}, 
   3.982928175612615*^9, 3.983755149042252*^9},
 CellLabel->
  "Out[148]=",ExpressionUUID->"a556ae39-0d1b-4053-b625-f4b1c08d53f6"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"rules", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"t", "'"}], "[", "\[Lambda]", "]"}], "->", 
      RowBox[{"E0", "/", 
       RowBox[{"f", "[", 
        RowBox[{"r", "[", "\[Lambda]", "]"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Phi]", "'"}], "[", "\[Lambda]", "]"}], "->", 
      RowBox[{"L", "/", 
       RowBox[{
        RowBox[{"r", "[", "\[Lambda]", "]"}], "^", "2"}]}]}]}], "}"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.982474706435665*^9, 3.982474709753111*^9}},
 CellLabel->
  "In[149]:=",ExpressionUUID->"2cc5dd2b-496f-4ee3-884d-e460008861f6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"norm", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       RowBox[{"f", "[", 
        RowBox[{"r", "[", "\[Lambda]", "]"}], "]"}]}], " ", 
      RowBox[{
       RowBox[{
        RowBox[{"t", "'"}], "[", "\[Lambda]", "]"}], "^", "2"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"r", "'"}], "[", "\[Lambda]", "]"}], "^", "2"}], "/", 
      RowBox[{"h", "[", 
       RowBox[{"r", "[", "\[Lambda]", "]"}], "]"}]}], "+", 
     RowBox[{
      RowBox[{
       RowBox[{"r", "[", "\[Lambda]", "]"}], "^", "2"}], " ", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]", "'"}], "[", "\[Lambda]", "]"}], "^", "2"}]}]}]}], 
   ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"normEq", "=", 
    RowBox[{"norm", "==", 
     RowBox[{"-", "\[Kappa]"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{"radialFirst", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"normEq", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"t", "'"}], "[", "\[Lambda]", "]"}], "->", 
       RowBox[{"E0", "/", 
        RowBox[{"f", "[", 
         RowBox[{"r", "[", "\[Lambda]", "]"}], "]"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Phi]", "'"}], "[", "\[Lambda]", "]"}], "->", 
       RowBox[{"L", "/", 
        RowBox[{
         RowBox[{"r", "[", "\[Lambda]", "]"}], "^", "2"}]}]}]}], "}"}]}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.982474924056273*^9, 3.982474932734989*^9}},
 CellLabel->
  "In[150]:=",ExpressionUUID->"159c3323-36ad-4285-8ee5-f57a50c7d4d6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Kappa]", "+", 
   FractionBox[
    SuperscriptBox["L", "2"], 
    SuperscriptBox[
     RowBox[{"r", "[", "\[Lambda]", "]"}], "2"]], "+", 
   FractionBox[
    RowBox[{
     SuperscriptBox["E0", "2"], " ", 
     RowBox[{"r", "[", "\[Lambda]", "]"}]}], 
    RowBox[{"2", "-", 
     RowBox[{"r", "[", "\[Lambda]", "]"}]}]], "+", 
   FractionBox[
    SuperscriptBox[
     RowBox[{
      SuperscriptBox["r", "\[Prime]",
       MultilineFunction->None], "[", "\[Lambda]", "]"}], "2"], 
    RowBox[{"h", "[", 
     RowBox[{"r", "[", "\[Lambda]", "]"}], "]"}]]}], "\[Equal]", 
  "0"}]], "Output",
 CellChangeTimes->{{3.982474924530176*^9, 3.982474933544983*^9}, 
   3.983755149068243*^9},
 CellLabel->
  "Out[152]=",ExpressionUUID->"575caccf-3377-44d0-8cb6-65b9e29c8d90"]
}, Open  ]]
}, Open  ]],


      RowBox[{"{", 
       RowBox[{"\"\<r\>\"", ",", "\"\<r^3 - b^2 r + 2 M b^2\>\""}], "}"}]}], 
     ",", 
     RowBox[{"Epilog", "->", 
      RowBox[{"{", 
       RowBox[{"Red", ",", 
        RowBox[{"PointSize", "[", "Large", "]"}], ",", 
        RowBox[{"Point", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"#", ",", "0"}], "}"}], "&"}], "/@", 
          RowBox[{"(", 
           RowBox[{"r", "/.", " ", 
            RowBox[{"NSolve", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"poly", "[", 

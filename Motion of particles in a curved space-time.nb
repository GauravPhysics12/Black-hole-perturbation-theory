            RowBox[{"3", " ", "M"}], ",", "lambdaNull"}], "}"}], "]"}], ",", 
         RowBox[{"Text", "[", 
          RowBox[{"\"\<Null Geodesic (3M)\>\"", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"3.5", " ", "M"}], ",", 
             RowBox[{"lambdaNull", "+", "0.02"}]}], "}"}]}], "]"}]}], 
        "}"}]}]}], "]"}]}]}]}]], "Input",

Cell[CellGroupData[{

Cell["Lyapunov calculation for double pendulum ", "Subsection",
 CellChangeTimes->{{3.9825415978337708`*^9, 3.9825415978367767`*^9}, 
   3.982541853576696*^9, {3.982541901381555*^9, 
   3.982541921506258*^9}},ExpressionUUID->"9839c81a-1a1f-4e38-a14d-\
c0734194730b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Parameters"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"g", "=", "9.81"}], ";", 
    RowBox[{"m1", "=", "1"}], ";", 
    RowBox[{"m2", "=", "1"}], ";", 
    RowBox[{"l1", "=", "1"}], ";", 
    RowBox[{"l2", "=", "1"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"2.", " ", "Hamiltonian"}], "&"}], " ", "Jacobian"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Theta]1", "[", "t", "]"}], ",", 
       RowBox[{"\[Theta]2", "[", "t", "]"}], ",", 
       RowBox[{"p1", "[", "t", "]"}], ",", 
       RowBox[{"p2", "[", "t", "]"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"T", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"m2", " ", 
         RowBox[{"l2", "^", "2"}], " ", 
         RowBox[{
          RowBox[{"p1", "[", "t", "]"}], "^", "2"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m1", "+", "m2"}], ")"}], " ", 
         RowBox[{"l1", "^", "2"}], " ", 
         RowBox[{
          RowBox[{"p2", "[", "t", "]"}], "^", "2"}]}], "-", 
        RowBox[{"2", " ", "m2", " ", "l1", " ", "l2", " ", 
         RowBox[{"p1", "[", "t", "]"}], " ", 
         RowBox[{"p2", "[", "t", "]"}], " ", 
         RowBox[{"Cos", "[", 
          RowBox[{
           RowBox[{"\[Theta]1", "[", "t", "]"}], "-", 
           RowBox[{"\[Theta]2", "[", "t", "]"}]}], "]"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", 
        RowBox[{"l1", "^", "2"}], " ", 
        RowBox[{"l2", "^", "2"}], " ", "m2", " ", 
        RowBox[{"(", 
         RowBox[{"m1", "+", 
          RowBox[{"m2", " ", 
           RowBox[{
            RowBox[{"Sin", "[", 
             RowBox[{
              RowBox[{"\[Theta]1", "[", "t", "]"}], "-", 
              RowBox[{"\[Theta]2", "[", "t", "]"}]}], "]"}], "^", "2"}]}]}], 
         ")"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"V", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{"m1", "+", "m2"}], ")"}]}], " ", "g", " ", "l1", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]1", "[", "t", "]"}], "]"}]}], "-", 
      RowBox[{"m2", " ", "g", " ", "l2", " ", 
       RowBox[{"Cos", "[", 
        RowBox[{"\[Theta]2", "[", "t", "]"}], "]"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"H", "=", 
     RowBox[{"T", "+", "V"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"forceField", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"H", ",", 
         RowBox[{"p1", "[", "t", "]"}]}], "]"}], ",", 
       RowBox[{"D", "[", 
        RowBox[{"H", ",", 
         RowBox[{"p2", "[", "t", "]"}]}], "]"}], ",", 
       RowBox[{"-", 
        RowBox[{"D", "[", 
         RowBox[{"H", ",", 
          RowBox[{"\[Theta]1", "[", "t", "]"}]}], "]"}]}], ",", 
       RowBox[{"-", 
        RowBox[{"D", "[", 
         RowBox[{"H", ",", 
          RowBox[{"\[Theta]2", "[", "t", "]"}]}], "]"}]}]}], "}"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"K", "=", 
     RowBox[{"Outer", "[", 
      RowBox[{"D", ",", "forceField", ",", "vars"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Deviation", " ", "Vector", " ", "Setup", " ", 
     RowBox[{"(", 
      RowBox[{"4", " ", "equations", " ", "instead", " ", "of", " ", "16"}], 
      ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"devVars", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"d1", "[", "t", "]"}], ",", 
       RowBox[{"d2", "[", "t", "]"}], ",", 
       RowBox[{"d3", "[", "t", "]"}], ",", 
       RowBox[{"d4", "[", "t", "]"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"devEqs", "=", 
     RowBox[{"Thread", "[", 
      RowBox[{
       RowBox[{"D", "[", 
        RowBox[{"devVars", ",", "t"}], "]"}], "==", 
       RowBox[{"K", ".", "devVars"}]}], "]"}]}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Solve"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"tMax", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"initialOrbit", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Theta]1", "[", "0", "]"}], "==", "1.5"}], ",", 
       RowBox[{
        RowBox[{"\[Theta]2", "[", "0", "]"}], "==", "1.5"}], ",", 
       RowBox[{
        RowBox[{"p1", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"p2", "[", "0", "]"}], "==", "0"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"initialDev", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"d1", "[", "0", "]"}], "==", 
        RowBox[{"10", "^", 
         RowBox[{"-", "6"}]}]}], ",", 
       RowBox[{
        RowBox[{"d2", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"d3", "[", "0", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"d4", "[", "0", "]"}], "==", "0"}]}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{
           RowBox[{"D", "[", 
            RowBox[{"vars", ",", "t"}], "]"}], "==", "forceField"}], "]"}], 
         ",", "devEqs", ",", "initialOrbit", ",", "initialDev"}], "]"}], ",", 
       
       RowBox[{"Join", "[", 
        RowBox[{"vars", ",", "devVars"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
       RowBox[{"MaxSteps", "->", 
        RowBox[{"10", "^", "6"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Calculate", " ", "Lambda"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"dVec", "[", "t_", "]"}], ":=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"d1", "[", "t", "]"}], ",", 
        RowBox[{"d2", "[", "t", "]"}], ",", 
        RowBox[{"d3", "[", "t", "]"}], ",", 
        RowBox[{"d4", "[", "t", "]"}]}], "}"}], "/.", " ", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"d0", "=", 
     RowBox[{"Norm", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"10", "^", 
         RowBox[{"-", "6"}]}], ",", "0", ",", "0", ",", "0"}], "}"}], "]"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"lambda", "[", "t_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", "t"}], ")"}], "*", 
      RowBox[{"Log", "[", 
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{"dVec", "[", "t", "]"}], "]"}], "/", "d0"}], "]"}]}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"lambda", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "0.1", ",", "tMax"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Time\>\"", ",", "\"\<\[Lambda]\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Principal Lyapunov Exponent Convergence\>\""}]}],
     "]"}]}]}]], "Input",
 CellChangeTimes->{{3.982541739601808*^9, 3.98254173960679*^9}, {

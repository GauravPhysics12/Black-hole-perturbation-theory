    RowBox[{"coords", "=", 
     RowBox[{"{", 
      RowBox[{"t", ",", "r", ",", "\[Theta]", ",", "\[Phi]"}], "}"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"g\[Mu]\[Nu]", "=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"f", "[", "r", "]"}]}], ",", 
        RowBox[{"1", "/", 
         RowBox[{"f", "[", "r", "]"}]}], ",", 

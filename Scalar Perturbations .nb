   RowBox[{
    RowBox[{"detg", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{"Det", "[", "g\[Mu]\[Nu]", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sqrtg", "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Abs", "[", "detg", "]"}], "]"}], "]"}]}], ";"}]}]}]], "Input",\


     RowBox[{"0", "\[LessEqual]", " ", "\[Theta]", "<", 
      FractionBox["\[Pi]", "2"]}], ",", 
     RowBox[{"0", "\[LessEqual]", " ", "\[Phi]", "\[LessEqual]", " ", 
      RowBox[{"2", " ", "\[Pi]"}]}], ",", 
     RowBox[{"r", "\[GreaterEqual]", "0"}], ",", 
     RowBox[{"1", "\[GreaterEqual]", "\[Chi]", "\[GreaterEqual]", " ", 
      RowBox[{"-", "1"}]}], ",", 
     RowBox[{"a", "\[GreaterEqual]", " ", "0"}]}], "}"}]}], ";"}]], "Input",

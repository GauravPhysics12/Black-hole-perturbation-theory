Cell[BoxData[
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"M", ">", "0"}], ",", 
     RowBox[{"r", ">", " ", "0"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
